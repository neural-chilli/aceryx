package main

import (
	"testing"

	"github.com/neural-chilli/aceryx-plugin-sdk-go/sdk"
)

func TestExecute(t *testing.T) {
	mock := sdk.NewMockContext()
	mock.SetCaseData("input_field", `"test-value"`)

	result := executeWithContext(mock)
	if result.Status != "ok" {
		t.Fatalf("expected ok, got %s: %s", result.Status, result.Error)
	}
	mock.AssertCalled(t, "CaseGet")
	mock.AssertCalled(t, "Log")
}
